rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the request from a signed-in user?
    function isAuth() {
      return request.auth != null;
    }

    // Helper: is the requesting user one of the chat participants?
    function isParticipant(chatId) {
      return isAuth() && request.auth.uid in chatId.split('_');
    }

    // ── Users ──────────────────────────────────────────────────────────────
    // Any signed-in user can read any profile (needed for user list/search).
    // A user can only write their own document.
    match /users/{userId} {
      allow read: if isAuth();
      allow create, update: if isAuth() && request.auth.uid == userId;
      allow delete: if false;
    }

    // ── Chats ─────────────────────────────────────────────────────────────
    // Only participants of a chat can read the chat metadata or its messages.
    match /chats/{chatId} {
      allow read, write: if isParticipant(chatId);

      match /messages/{messageId} {
        allow read: if isParticipant(chatId);
        allow create: if isParticipant(chatId)
                      && request.auth.uid == request.resource.data.senderId;
        allow update: if isParticipant(chatId)
                      && request.auth.uid == resource.data.senderId;
        allow delete: if false;
      }

      match /typing/{userId} {
        allow read: if isParticipant(chatId);
        allow write: if isParticipant(chatId) && request.auth.uid == userId;
      }
    }

    // ── Calls ─────────────────────────────────────────────────────────────
    // Only the two people in the call (chatId == uid1_uid2) can read/write.
    match /calls/{chatId} {
      allow read, write: if isParticipant(chatId);

      match /callerCandidates/{doc} {
        allow read, write: if isParticipant(chatId);
      }
      match /calleeCandidates/{doc} {
        allow read, write: if isParticipant(chatId);
      }
    }
  }
}
